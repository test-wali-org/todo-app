#!/usr/bin/env bash
# Secret detection pre-commit hook — TruffleHog
# Install TruffleHog: brew install trufflehog
set -euo pipefail

# ── Colours & symbols ─────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

TICK="${GREEN}✔${NC}"
CROSS="${RED}✖${NC}"
WARN="${YELLOW}⚠${NC}"
LOCK="${CYAN}🔒${NC}"

# ── Spinner ───────────────────────────────────────────────────────────────
SPINNER_PID=""
spinner() {
  local msg="$1"
  local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  local i=0
  while true; do
    printf "\r  ${CYAN}${frames[$i]}${NC}  ${msg}" >&2
    i=$(( (i + 1) % ${#frames[@]} ))
    sleep 0.08
  done
}

spinner_start() { spinner "$1" & SPINNER_PID=$!; }
spinner_stop()  {
  if [[ -n "$SPINNER_PID" ]]; then
    kill "$SPINNER_PID" 2>/dev/null || true
    wait "$SPINNER_PID" 2>/dev/null || true
    SPINNER_PID=""
    printf "\r\033[K" >&2   # clear the spinner line
  fi
}
trap spinner_stop EXIT

# ── Header ────────────────────────────────────────────────────────────────
echo -e "\n${LOCK} ${BOLD}Secret Detection${NC}  ${DIM}(TruffleHog)${NC}\n" >&2

# ── 1. Check trufflehog ───────────────────────────────────────────────────
if ! command -v trufflehog >/dev/null 2>&1; then
  echo -e "  ${WARN}  trufflehog not found — skipping scan" >&2
  echo -e "  ${DIM}Install: brew install trufflehog${NC}\n" >&2
  exit 0
fi

# ── 2. Get staged files ───────────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
if [[ -z "$STAGED_FILES" ]]; then
  echo -e "  ${DIM}No staged files — nothing to scan.${NC}\n" >&2
  exit 0
fi

FILE_COUNT=$(echo "$STAGED_FILES" | wc -l | tr -d ' ')
echo -e "  ${DIM}Staged files: ${FILE_COUNT}${NC}" >&2

# ── 3. Extract only staged (added) lines per file, preserve real line nos ─
spinner_start "Preparing staged diff…"
TMP_DIR=$(mktemp -d)
trap 'spinner_stop; rm -rf "$TMP_DIR" "$LINE_MAP_DIR"' EXIT

# LINE_MAP_DIR stores JSON: tmpfile → [(real_lineno, content), ...]
LINE_MAP_DIR=$(mktemp -d)

python3 - "$TMP_DIR" "$LINE_MAP_DIR" <<'PYEOF'
import subprocess, sys, json, os, re

tmp      = sys.argv[1]
map_dir  = sys.argv[2]

staged = subprocess.check_output(
    ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
    text=True,
).strip().splitlines()

SKIP_FILES = {'.secrets-allowlist'}

for filepath in staged:
    if os.path.basename(filepath) in SKIP_FILES:
        continue   # never scan allowlist files — they intentionally contain secret patterns
    if not filepath:
        continue
    diff = subprocess.run(
        ["git", "diff", "--cached", "--unified=0", "--", filepath],
        capture_output=True, text=True,
    ).stdout

    # Collect removed line contents so we can exclude re-added unchanged lines
    # (happens when a file gains a trailing newline — git shows the last line
    # as both removed and re-added with identical content)
    removed_contents = set()
    for dl in diff.splitlines():
        if dl.startswith("-") and not dl.startswith("---"):
            removed_contents.add(dl[1:])

    added = []          # (real_line_no, content)
    new_lineno = 0
    for dl in diff.splitlines():
        if dl.startswith("@@"):
            m = re.search(r"\+(\d+)", dl)
            if m:
                new_lineno = int(m.group(1)) - 1
        elif dl.startswith("+") and not dl.startswith("+++"):
            new_lineno += 1
            content = dl[1:]
            if content not in removed_contents:   # skip re-added unchanged lines
                added.append((new_lineno, content))
        elif not dl.startswith("-") and not dl.startswith("\\"):
            new_lineno += 1

    if not added:
        continue

    ext      = os.path.splitext(filepath)[1] or ".txt"
    safe     = filepath.replace("/", "__")
    tmp_file = os.path.join(tmp, safe + ext)

    with open(tmp_file, "w") as f:
        for _, content in added:
            f.write(content + "\n")

    # store the line map so bash can look up real line numbers
    with open(os.path.join(map_dir, safe + ext + ".json"), "w") as f:
        json.dump({"file": filepath, "lines": added}, f)
PYEOF

spinner_stop
echo -e "  ${TICK}  Staged diff ready (added lines only)" >&2

# ── 4. Detect trufflehog config ───────────────────────────────────────────
REPO_ROOT=$(git rev-parse --show-toplevel)
CONFIG_FLAG=""
if [[ -f "$REPO_ROOT/.trufflehog.yaml" ]]; then
  CONFIG_FLAG="--config $REPO_ROOT/.trufflehog.yaml"
  echo -e "  ${TICK}  Custom detector config found" >&2
fi

# ── 5. Build allowlist (global + per-repo) ───────────────────────────────
GLOBAL_ALLOWLIST="$HOME/.secrets-allowlist"
REPO_ALLOWLIST="$REPO_ROOT/.secrets-allowlist"

load_allowlist() {
  local entries=()
  for f in "$GLOBAL_ALLOWLIST" "$REPO_ALLOWLIST"; do
    [[ -f "$f" ]] || continue
    while IFS= read -r pat || [[ -n "$pat" ]]; do
      # skip blank lines and comments
      [[ -z "$pat" || "$pat" == \#* ]] && continue
      entries+=("$pat")
    done < "$f"
  done
  printf '%s\n' "${entries[@]+"${entries[@]}"}"
}

ALLOWLIST_ENTRIES=$(load_allowlist)

is_allowlisted() {
  local raw="$1"
  [[ -z "$ALLOWLIST_ENTRIES" || -z "$raw" ]] && return 1
  while IFS= read -r pat; do
    [[ -z "$pat" ]] && continue
    # raw contains pattern  (e.g. allowlist: "mypassword")
    [[ "$raw" == *"$pat"* ]] && return 0
    # pattern contains raw  (e.g. allowlist has full URL, raw is URL minus db name)
    [[ "$pat" == *"$raw"* ]] && return 0
    # pattern contains raw  (e.g. allowlist has full URL, raw is URL minus db name)
    [[ "$pat" == *"$raw"* ]] && return 0
  done <<< "$ALLOWLIST_ENTRIES"
  return 1
}

# Show which allowlists are active
if [[ -f "$GLOBAL_ALLOWLIST" ]]; then
  echo -e "  ${TICK}  Global allowlist active  ${DIM}(~/.secrets-allowlist)${NC}" >&2
fi
if [[ -f "$REPO_ALLOWLIST" ]]; then
  echo -e "  ${TICK}  Repo allowlist active    ${DIM}(.secrets-allowlist)${NC}" >&2
fi

# ── 6. Run scan ───────────────────────────────────────────────────────────
spinner_start "Scanning for secrets…"
RAW_FINDINGS=$(trufflehog filesystem "$TMP_DIR" --json --no-update $CONFIG_FLAG 2>/dev/null \
  | grep -v '^$' || true)
spinner_stop

# ── 7. Filter allowlisted findings ───────────────────────────────────────
FINDINGS=""
SKIPPED=0
while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  RAW_VAL=$(echo "$line" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(d.get('Raw') or d.get('RawV2') or '')
" 2>/dev/null || echo "")
  if is_allowlisted "$RAW_VAL"; then
    SKIPPED=$((SKIPPED + 1))
  else
    FINDINGS+="$line"$'\n'
  fi
done <<< "$RAW_FINDINGS"

FINDINGS="${FINDINGS%$'\n'}"   # trim trailing newline

[[ "$SKIPPED" -gt 0 ]] && \
  echo -e "  ${DIM}↳ ${SKIPPED} finding(s) suppressed by allowlist${NC}" >&2

# ── 8. Results ────────────────────────────────────────────────────────────
if [[ -z "$FINDINGS" ]]; then
  echo -e "  ${TICK}  ${GREEN}${BOLD}No secrets detected${NC} — all clear!\n" >&2
  exit 0
fi

COUNT=$(echo "$FINDINGS" | grep -c '"DetectorName"' || true)
echo -e "  ${CROSS}  ${RED}${BOLD}${COUNT} secret(s) detected in staged files${NC}\n" >&2

echo -e "${RED}┌──────────────────────────────────────────────────────┐${NC}" >&2
echo -e "${RED}│              COMMIT BLOCKED — SECRETS FOUND           │${NC}" >&2
echo -e "${RED}└──────────────────────────────────────────────────────┘${NC}\n" >&2

IDX=0
while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  IDX=$((IDX + 1))

  TYPE=$(echo "$line" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(d.get('DetectorName', 'unknown'))
" 2>/dev/null || echo "unknown")

  FILE=$(echo "$line" | python3 -c "
import sys, json, os
d    = json.load(sys.stdin)
tmp  = '$TMP_DIR'
mdir = '$LINE_MAP_DIR'
fs_file = (d.get('SourceMetadata') or {}).get('Data', {}).get('Filesystem', {}).get('file', '')
if not fs_file:
    print('unknown'); sys.exit()
# tmp_file is like /tmp/.../safe__path.js  — strip tmp prefix to get safe name
safe_name = os.path.basename(fs_file)
map_path  = os.path.join(mdir, safe_name + '.json')
if os.path.exists(map_path):
    info = json.load(open(map_path))
    print(info.get('file', safe_name))
else:
    print(fs_file.replace(tmp + '/', '').replace(tmp, '') or 'unknown')
" 2>/dev/null || echo "unknown")

  LINE_NO=$(echo "$line" | python3 -c "
import sys, json, os
d    = json.load(sys.stdin)
mdir = '$LINE_MAP_DIR'
fs   = (d.get('SourceMetadata') or {}).get('Data', {}).get('Filesystem', {})
fs_file  = fs.get('file', '')
tmp_line = fs.get('line', 0)
safe_name = os.path.basename(fs_file)
map_path  = os.path.join(mdir, safe_name + '.json')
if os.path.exists(map_path) and tmp_line:
    lines = json.load(open(map_path)).get('lines', [])
    idx   = tmp_line - 1
    print(lines[idx][0] if 0 <= idx < len(lines) else tmp_line)
else:
    print(tmp_line or '?')
" 2>/dev/null || echo "?")

  RAW=$(echo "$line" | python3 -c "
import sys, json
d = json.load(sys.stdin)
r = (d.get('Raw') or '')[:50]
print(r[:6] + '...' + r[-4:] if len(r) > 10 else r)
" 2>/dev/null || echo "")

  VERIFIED=$(echo "$line" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print('YES — live credential!' if d.get('Verified') else 'no')
" 2>/dev/null || echo "unknown")

  echo -e "  ${RED}[${IDX}]${NC} ${BOLD}${TYPE}${NC}" >&2
  echo -e "      ${DIM}File    :${NC} ${FILE}${DIM} (line ${LINE_NO})${NC}" >&2
  echo -e "      ${DIM}Value   :${NC} ${YELLOW}${RAW}${NC}" >&2
  if [[ "$VERIFIED" == YES* ]]; then
    echo -e "      ${DIM}Verified:${NC} ${RED}${BOLD}${VERIFIED}${NC}" >&2
  else
    echo -e "      ${DIM}Verified:${NC} ${DIM}${VERIFIED}${NC}" >&2
  fi
  echo "" >&2
done <<< "$FINDINGS"

echo -e "${DIM}  ──────────────────────────────────────────────────────${NC}" >&2
echo -e "  ${WARN}  ${BOLD}What to do:${NC}" >&2
echo -e "      1. Remove or rotate the secret from your code" >&2
echo -e "      2. Use env vars or a secrets manager instead" >&2
echo -e "      3. False positive? Add the value to:" >&2
echo -e "           ${YELLOW}~/.secrets-allowlist${NC}   ← applies to all your repos" >&2
echo -e "           ${YELLOW}.secrets-allowlist${NC}      ← applies to this repo only" >&2
echo -e "      4. ${DIM}Bypass (DANGER): git commit --no-verify${NC}\n" >&2
exit 1
