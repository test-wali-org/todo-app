#!/usr/bin/env bash
# Secret detection pre-commit hook — TruffleHog only
# Install TruffleHog: brew install trufflehog
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

if ! command -v trufflehog >/dev/null 2>&1; then
  echo -e "${YELLOW}[secrets] trufflehog not found — skipping scan${NC}"
  echo "  Install: brew install trufflehog"
  exit 0
fi

STAGED_FILES=$(git diff --cached --name-only 2>/dev/null || true)
if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# Copy staged content to a temp dir (trufflehog needs files on disk)
TMP_DIR=$(mktemp -d)
trap 'rm -rf "$TMP_DIR"' EXIT

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  mkdir -p "$TMP_DIR/$(dirname "$file")"
  git show ":$file" > "$TMP_DIR/$file" 2>/dev/null || true
done <<< "$STAGED_FILES"

CONFIG_FLAG=""
[[ -f "$(git rev-parse --show-toplevel)/.trufflehog.yaml" ]] && \
  CONFIG_FLAG="--config $(git rev-parse --show-toplevel)/.trufflehog.yaml"

FINDINGS=$(trufflehog filesystem "$TMP_DIR" --json --no-update $CONFIG_FLAG 2>/dev/null \
  | grep -v '^$' || true)

if [[ -z "$FINDINGS" ]]; then
  echo -e "${GREEN}[secrets] No secrets detected. Proceeding.${NC}"
  exit 0
fi

echo -e "${RED}[secrets] Commit blocked — secrets detected in staged files:${NC}"
echo ""

while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  TYPE=$(echo "$line" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(d.get('DetectorName', 'unknown'))
" 2>/dev/null || echo "unknown")
  FILE=$(echo "$line" | python3 -c "
import sys, json, os
d = json.load(sys.stdin)
f = (d.get('SourceMetadata') or {}).get('Data', {}).get('Filesystem', {}).get('file', 'unknown')
print(f.replace('$TMP_DIR' + '/', '').replace('$TMP_DIR', '') if f != 'unknown' else 'unknown')
" 2>/dev/null || echo "unknown")
  RAW=$(echo "$line" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print((d.get('Raw') or '')[:50])
" 2>/dev/null || echo "")
  echo "  Type : $TYPE"
  echo "  File : $FILE"
  [[ -n "$RAW" ]] && echo "  Value: ${RAW}..."
  echo ""
done <<< "$FINDINGS"

echo -e "  To allowlist a false positive: add the value to ${YELLOW}.secrets-allowlist${NC}"
echo    "  To bypass (DANGER): git commit --no-verify"
exit 1
